{
  "expo": {
    "name": "Wanderlust",
    "slug": "wanderlust",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wanderlust",
    "userInterfaceStyle": "light",
    "primaryColor": "#bb8b4b",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.wanderlust.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Wanderlust nutzt deinen Standort, um dich auf der Gipfelkarte zu zeigen und zu prüfen, ob du nah genug an einem Ort bist, um sein Stockschild zu prägen. Kein Tracking, keine Bewegungsprofile."
      }
    },
    "android": {
      "package": "app.wanderlust.mobile",
      "permissions": ["android.permission.ACCESS_COARSE_LOCATION", "android.permission.ACCESS_FINE_LOCATION"],
      "adaptiveIcon": {
        "backgroundColor": "#1c2620",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1c2620",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.4"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
